{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Nexus Docs",
  "description": "Documentation for the Nexus multi-agent coordination bus",
  "colors": {
    "primary": "#00D992",
    "light": "#2FD6A1",
    "dark": "#10B981",
    "background": {
      "dark": "#101010"
    }
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/nexus.svg",
    "dark": "/logo/nexus.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/Akash8585/nexus"
      },
      {
        "label": "Dashboard",
        "href": "http://localhost:3000"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Quickstart",
      "href": "/quickstart"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Akash8585/nexus"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/agents",
              "concepts/messages",
              "concepts/topics",
              "concepts/context-store",
              "concepts/pipelines",
              "concepts/dead-letter-queue"
            ]
          },
          {
            "group": "SDK",
            "pages": ["sdk/python", "sdk/javascript"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "REST API",
            "pages": [
              "api-reference/authentication",
              "api-reference/agents",
              "api-reference/messages",
              "api-reference/topics",
              "api-reference/context",
              "api-reference/pipelines",
              "api-reference/deadletter",
              "api-reference/keys-and-team",
              "api-reference/websocket"
            ]
          }
        ]
      }
    ]
  }
}
